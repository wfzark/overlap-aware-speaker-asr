{
  "label": "experimental/frontier",
  "rq": "RQ58: Corrected router with n-gram KL-divergence detector",
  "closes_issue": 974,
  "source_data": "results/external_sanity_check/aishell4/rq1_aishell4_validation_results.json",
  "source_label": "external/sanity-check",
  "method": "Reanalysis only (no Whisper / no ASR / no LLM run). Replaces RQ16's language-id-entropy detector with a character 2-gram KL-divergence anomaly detector (RQ34) in the corrected router. Reference 2-gram distribution built from the 40 non-hallucinated tracks' separated text (RQ34 build_reference_distribution, n=2). Per-window score is the MAX-across-speakers KL (RQ12/RQ13 worst-case-track convention). Threshold empirically calibrated at >=90% specificity on the 40 non-hallucinated tracks (NOT RQ34's non-reproducible 3.30; RQ40 PR #957 showed 3.30 gives 32.5% specificity). Route: KL >= threshold -> MIXED, else SEPARATED. Per-window cpWER is the chosen route's stored word-level cpWER (matches RQ16 bit-for-bit). Bootstrap 10,000 resamples, seed=42, percentile + BCa CIs (RQ39 framework).",
  "meeting_id": "M_R003S02C01",
  "n_windows": 77,
  "n_hallucinated": 37,
  "n_nonhallucinated": 40,
  "n_mode_s": 2,
  "n_diverse_hallucination": 35,
  "mode_s_window_ids": [
    22,
    30
  ],
  "hallucination_label": "always_separated_cpwer > 1.0 (37/40 split, RQ12)",
