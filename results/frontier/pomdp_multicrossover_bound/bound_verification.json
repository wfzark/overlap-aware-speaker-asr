  "hypotheses": {
    "H18a_bound_is_O(kL_over_n2)": {
      "supported": true,
      "log_log_slope_k1": -2.0,
      "log_log_slope_k2": -2.0,
      "k_scaling_ratio": 2.0,
      "note": "Bound 5 (discretisation) = k*L*h^2/(2D) with h=D/n gives O(k*L/n^2). Log-log slope vs n is ~ -2 at both k=1 and k=2. The bound at k=2 is ~ k2*L2/(k1*L1) times the k=1 bound."
    },
    "H18b_tight_at_g02_k2": {
      "supported": true,
      "empirical_regret": 0.04672083,
      "bound5": 0.04634614,
      "relative_error": 0.008,
      "note": "At g=0.2 (k=2), Bound 5 (uniform, k*L*d^2/2D) = 0.046346 vs empirical router v2 regret = 0.046721. Relative error 0.0080 < 0.10. The k=2 factor captures the second crossover's contribution; the bound explains WHY router v2 fails on AISHELL-4 (large regret from the missed crossover)."
    },
    "H18c_k_dependent_sample_complexity": {
      "supported": true,
      "formula": "n >= sqrt(k * L * D / (2 * eps))",
      "sqrt_k_ratio": 1.4142,
      "note": "From k*L*h^2/(2D) <= eps with h=D/n: n >= sqrt(k*L*D/(2*eps)). The multi-crossover case needs sqrt(k) more strata. At g=0.2 (k=2) the ratio vs k=1 is ~ sqrt(2) = 1.414."
    }
